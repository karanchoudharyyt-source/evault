import React, { useState } from 'react'
import { motion } from 'framer-motion'
import { TrendingUp, TrendingDown, ChevronUp, ChevronDown, Minus, ExternalLink } from 'lucide-react'
import { Pack, PACKS } from '@/data/packs'
import { Badge } from '@/components/ui/badge'
import { Button } from '@/components/ui/button'

type Category = 'all' | 'pokemon' | 'basketball' | 'football' | 'baseball' | 'sports'
type SortKey = 'evRatio' | 'calibratedEv' | 'price' | 'totalPulls' | 'buybackMultiplier'

const SIGNAL_STYLE: Record<string, string> = {
  'GREAT VALUE': 'bg-green-500/15 text-green-400 border-green-500/30',
  'GOOD VALUE': 'bg-teal-500/15 text-teal-400 border-teal-500/30',
  'FAIR VALUE': 'bg-yellow-500/15 text-yellow-400 border-yellow-500/30',
  'BELOW EV': 'bg-red-500/15 text-red-400 border-red-500/30',
}

const EV_COLOR = (ratio: number) => {
  if (ratio >= 1.3) return 'text-green-400'
  if (ratio >= 1.0) return 'text-teal-400'
  if (ratio >= 0.9) return 'text-yellow-400'
  return 'text-red-400'
}

const CAT_LABEL: Record<string, string> = {
  pokemon: 'PKMN', basketball: 'NBA', football: 'NFL', baseball: 'MLB', sports: 'SPORT',
}

const PackRow = ({ pack, index }: { pack: Pack; index: number }) => {
  const [hovered, setHovered] = useState(false)
  return (
    <motion.tr
      initial={{ opacity: 0, y: 8 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ delay: index * 0.04, duration: 0.22 }}
      onHoverStart={() => setHovered(true)}
      onHoverEnd={() => setHovered(false)}
      className={`border-b border-border/40 transition-colors cursor-pointer ${hovered ? 'bg-primary/5' : ''}`}
    >
      <td className="px-4 py-4 w-10">
        <span className="font-mono text-sm font-black text-muted-foreground/50">#{pack.rank}</span>
      </td>
      <td className="px-4 py-4">
        <div className="flex items-center gap-3">
          <div className="w-11 h-11 rounded-lg overflow-hidden flex-shrink-0 bg-secondary/50 border border-border/50">
            <img src={pack.imageUrl} alt={pack.name} className="w-full h-full object-cover"
              onError={(e) => {
                const el = e.target as HTMLImageElement
                el.style.display = 'none'
                const p = el.parentElement
                if (p) p.innerHTML = `<div class="w-full h-full flex items-center justify-center text-[9px] font-black text-primary">${CAT_LABEL[pack.category]}</div>`
              }} />
          </div>
          <div>
            <div className="flex items-center gap-2 flex-wrap">
              <span className={`font-bold text-sm ${hovered ? 'text-primary' : 'text-foreground'} transition-colors`}>{pack.name}</span>
              <span className="text-[9px] font-black uppercase tracking-wider px-1.5 py-0.5 rounded bg-secondary/80 text-muted-foreground">{CAT_LABEL[pack.category]}</span>
            </div>
            <div className="text-[11px] text-muted-foreground mt-0.5">
              {pack.totalPulls.toLocaleString()} pulls · <span className="text-foreground/60">{pack.topCard}</span>
            </div>
          </div>
        </div>
      </td>
      <td className="px-4 py-4 text-right">
        <span className="font-mono text-sm font-bold">${pack.price.toFixed(2)}</span>
      </td>
      <td className="px-4 py-4 text-right">
        <div className="flex flex-col items-end gap-0.5">
          <span className={`font-mono text-xl font-black tabular-nums leading-none ${EV_COLOR(pack.evRatio)}`}>{pack.evRatio.toFixed(3)}</span>
          <div className="flex items-center gap-1">
            {pack.evRatio >= 1 ? <TrendingUp className="w-3 h-3 text-green-400" /> : <TrendingDown className="w-3 h-3 text-red-400" />}
            <span className="text-[10px] text-muted-foreground font-mono">x EV</span>
          </div>
        </div>
      </td>
      <td className="px-4 py-4 text-right">
        <span className={`font-mono text-sm font-black ${EV_COLOR(pack.evRatio)}`}>${pack.calibratedEv.toFixed(2)}</span>
      </td>
      <td className="px-4 py-4 min-w-[140px]">
        <div className="flex flex-col gap-1.5">
          <div className="flex justify-between text-[10px] font-bold">
            <span className="text-muted-foreground">Win Rate</span>
            <span className="font-mono">{pack.winRateAbovePackPrice.toFixed(1)}%</span>
          </div>
          <div className="h-1.5 rounded-full bg-border/60 overflow-hidden">
            <motion.div
              initial={{ width: 0 }}
              animate={{ width: `${Math.min(pack.winRateAbovePackPrice * 3, 100)}%` }}
              transition={{ duration: 0.8, delay: index * 0.05 }}
              className={`h-full rounded-full ${pack.evRatio >= 1 ? 'bg-green-400' : 'bg-yellow-400'}`}
            />
          </div>
        </div>
      </td>
      <td className="px-4 py-4 text-center">
        <span className={`text-sm font-mono font-black ${pack.buybackMultiplier >= 1 ? 'text-green-400' : 'text-muted-foreground'}`}>
          {pack.buybackMultiplier.toFixed(2)}x
        </span>
      </td>
      <td className="px-4 py-4 text-center">
        <Badge className={`text-[10px] font-black uppercase tracking-wider border ${SIGNAL_STYLE[pack.signal]} px-2`}>
          {pack.signal}
        </Badge>
      </td>
      <td className="px-4 py-4 text-right">
        <Button size="sm" variant="outline"
          className="h-8 text-[11px] font-black gap-1.5 border-primary/30 text-primary hover:bg-primary/10 hover:border-primary">
          View <ExternalLink className="w-3 h-3" />
        </Button>
      </td>
    </motion.tr>
  )
}

export default function PackTable() {
  const [cat, setCat] = useState<Category>('all')
  const [sortKey, setSortKey] = useState<SortKey>('evRatio')
  const [sortDir, setSortDir] = useState<'asc' | 'desc'>('desc')

  const categories: { key: Category; label: string }[] = [
    { key: 'all', label: `All (${PACKS.length})` },
    { key: 'pokemon', label: `Pokémon (${PACKS.filter(p => p.category === 'pokemon').length})` },
    { key: 'basketball', label: `Basketball (${PACKS.filter(p => p.category === 'basketball').length})` },
    { key: 'football', label: `Football (${PACKS.filter(p => p.category === 'football').length})` },
    { key: 'baseball', label: `Baseball (${PACKS.filter(p => p.category === 'baseball').length})` },
    { key: 'sports', label: `Sports (${PACKS.filter(p => p.category === 'sports').length})` },
  ]

  const filtered = PACKS
    .filter(p => cat === 'all' || p.category === cat)
    .sort((a, b) => sortDir === 'desc' ? (b[sortKey] as number) - (a[sortKey] as number) : (a[sortKey] as number) - (b[sortKey] as number))

  const handleSort = (key: SortKey) => {
    if (sortKey === key) setSortDir(d => d === 'desc' ? 'asc' : 'desc')
    else { setSortKey(key); setSortDir('desc') }
  }

  const SI = ({ col }: { col: SortKey }) => sortKey !== col
    ? <Minus className="w-3 h-3 text-muted-foreground/30" />
    : sortDir === 'desc' ? <ChevronDown className="w-3 h-3 text-primary" /> : <ChevronUp className="w-3 h-3 text-primary" />

  return (
    <div className="rounded-xl border border-border/60 overflow-hidden bg-card/30 backdrop-blur-sm">
      <div className="px-5 py-3.5 border-b border-border/60 bg-[#060f1f]/60 flex flex-col md:flex-row md:items-center justify-between gap-3">
        <h2 className="font-black text-sm uppercase tracking-widest">Pack Monitor</h2>
        <div className="flex items-center gap-1 flex-wrap">
          {categories.map(c => (
            <button key={c.key} onClick={() => setCat(c.key)}
              className={`h-7 px-3 rounded-md text-[11px] font-bold transition-all ${cat === c.key ? 'bg-primary text-primary-foreground' : 'bg-secondary/50 text-muted-foreground hover:text-foreground hover:bg-secondary'}`}>
              {c.label}
            </button>
          ))}
        </div>
      </div>
      <div className="overflow-x-auto">
        <table className="w-full">
          <thead>
            <tr className="border-b border-border/40 bg-[#040b17]/40">
              <th className="px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest text-muted-foreground/70 w-10">#</th>
              <th className="px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest text-muted-foreground/70">Pack</th>
              <th className="px-4 py-3 text-right text-[10px] font-black uppercase tracking-widest text-muted-foreground/70 cursor-pointer hover:text-primary" onClick={() => handleSort('price')}>
                <span className="flex items-center justify-end gap-1">Price <SI col="price" /></span>
              </th>
              <th className="px-4 py-3 text-right text-[10px] font-black uppercase tracking-widest text-muted-foreground/70 cursor-pointer hover:text-primary" onClick={() => handleSort('evRatio')}>
                <span className="flex items-center justify-end gap-1">EV Ratio <SI col="evRatio" /></span>
              </th>
              <th className="px-4 py-3 text-right text-[10px] font-black uppercase tracking-widest text-muted-foreground/70 cursor-pointer hover:text-primary" onClick={() => handleSort('calibratedEv')}>
                <span className="flex items-center justify-end gap-1">Calibrated EV <SI col="calibratedEv" /></span>
              </th>
              <th className="px-4 py-3 text-left text-[10px] font-black uppercase tracking-widest text-muted-foreground/70 min-w-[140px]">Win Rate</th>
              <th className="px-4 py-3 text-center text-[10px] font-black uppercase tracking-widest text-muted-foreground/70 cursor-pointer hover:text-primary" onClick={() => handleSort('buybackMultiplier')}>
                <span className="flex items-center justify-center gap-1">Buyback <SI col="buybackMultiplier" /></span>
              </th>
              <th className="px-4 py-3 text-center text-[10px] font-black uppercase tracking-widest text-muted-foreground/70">Signal</th>
              <th className="px-4 py-3 text-right text-[10px] font-black uppercase tracking-widest text-muted-foreground/70">Action</th>
            </tr>
          </thead>
          <tbody>
            {filtered.map((pack, i) => <PackRow key={pack.id} pack={pack} index={i} />)}
          </tbody>
        </table>
      </div>
    </div>
  )
}
